# ── AISstream ──────────────────────────────────────────────
# Get your free key at https://aisstream.io
AISSTREAM_KEY=your_aisstream_api_key_here

# ── Ships to track ─────────────────────────────────────────
# Comma-separated MMSIs (find them in the MarineTraffic app)
TARGET_MMSIS=123456789,987654321

# ── Geofence ───────────────────────────────────────────────
# Centre point of the zone you want to monitor
ZONE_LAT=1.264
ZONE_LON=103.822
# Radius in kilometres — ship must come within this distance to trigger
ZONE_RADIUS_KM=5

# ── Pushover ───────────────────────────────────────────────
# https://pushover.net — create an app to get a token
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key

# ── Telegram ───────────────────────────────────────────────
# 1. Message @BotFather on Telegram to create a bot → get TG_TOKEN
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TG_TOKEN>/getUpdates
#    to find your TG_CHAT_ID
TG_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# ── Webhook ────────────────────────────────────────────────
# Optional: leave blank to skip
WEBHOOK_URL=https://your-endpoint.example.com/ship-alert
